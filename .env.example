# Configuración de EMAIL
# Lee este archivo para saber cómo configurar el envío de emails

# ============================================
# OPCIÓN 1: Usando Gmail
# ============================================
# 1. Abre tu cuenta de Gmail
# 2. Ve a: https://myaccount.google.com/apppasswords
# 3. Crea una "contraseña de aplicación" para Flask
# 4. Copia la contraseña generada (sin espacios)
# 5. Reemplaza los valores abajo y renombra este archivo a .env

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion
MAIL_DEFAULT_SENDER=tu-email@gmail.com

# ============================================
# OPCIÓN 2: Usando otro servicio (Outlook, Sendgrid, etc)
# ============================================
# Reemplaza los valores según el proveedor

# ============================================
# INSTRUCCIONES PARA PRODUCCIÓN
# ============================================
# 1. Rename este archivo a .env
# 2. Rellena tus credenciales
# 3. Instala python-dotenv: pip install python-dotenv
# 4. En app.py descomentar: from dotenv import load_dotenv; load_dotenv()
# 5. Reinicia Flask

# NUNCA hagas push de .env a Git (agregalo a .gitignore)
